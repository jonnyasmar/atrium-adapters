{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "list_recent_sessions output",
  "description": "Output schema for the list_recent_sessions method.",
  "type": "object",
  "required": ["sessions"],
  "properties": {
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "cwd", "lastActive"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique session identifier."
          },
          "name": {
            "oneOf": [
              { "type": "string" },
              { "type": "null" }
            ],
            "description": "Optional human-readable session name."
          },
          "cwd": {
            "type": "string",
            "minLength": 1,
            "description": "Working directory of the session."
          },
          "lastActive": {
            "type": "string",
            "description": "ISO 8601 timestamp of last activity."
          }
        },
        "additionalProperties": false
      },
      "description": "List of recent sessions, sorted by lastActive descending."
    }
  },
  "additionalProperties": false
}
