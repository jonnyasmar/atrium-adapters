{
  "sdkVersion": 2,
  "name": "antigravity",
  "displayName": "Antigravity",
  "description": "Google's agent-first terminal CLI (successor to Gemini CLI)",
  "accent": "#14b8a6",
  "binary": "agy",
  "version": "0.5.2",
  "icon": "icon.svg",
  "skillInstallPath": "~/.gemini/antigravity-cli/skills/atrium/SKILL.md",
  "skillsDir": "~/.gemini/antigravity-cli/skills",
  "binaryDiscovery": {
    "commands": [
      "agy"
    ],
    "wellKnownPaths": [
      "/opt/homebrew/bin/agy",
      "/usr/local/bin/agy",
      "~/.local/bin/agy",
      "~/.npm/bin/agy"
    ]
  },
  "hooks": {
    "session-start": "atrium://hooks/antigravity/session-start",
    "session-end": "atrium://hooks/antigravity/session-end",
    "pre-tool-use": "atrium://hooks/antigravity/pre-tool-use",
    "post-tool-use": "atrium://hooks/antigravity/post-tool-use",
    "user-prompt-submit": "atrium://hooks/antigravity/user-prompt-submit",
    "stop": "atrium://hooks/antigravity/stop"
  },
  "methods": {
    "build_launch_command": {
      "script": "build_launch_command.sh"
    },
    "build_resume_command": {
      "script": "build_resume_command.sh"
    },
    "list_recent_sessions": {
      "script": "list_recent_sessions.sh"
    },
    "hooks": {
      "script": "hooks.sh"
    },
    "launcher_options": {
      "static": "launcher_options.json"
    }
  },
  "sessionExtractor": {
    "script": "extract_session.sh",
    "schemaVersion": 1,
    "supportsDepths": [
      "quick",
      "standard",
      "deep"
    ]
  },
  "hookEnvelopes": {
    "sessionStartManifest": {
      "kind": "identity"
    },
    "userPromptSubmit": {
      "kind": "hookSpecificOutput",
      "hookEventName": "UserPromptSubmit",
      "includeSystemMessage": false
    },
    "preToolUse": {
      "kind": "none"
    },
    "postToolUse": {
      "kind": "none"
    }
  }
}
