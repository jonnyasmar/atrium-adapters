{
  "sdkVersion": 2,
  "name": "claude-code",
  "displayName": "Claude Code",
  "description": "Anthropic's AI coding assistant",
  "accent": "#d97757",
  "binary": "claude",
  "version": "1.16.10",
  "skillInstallPath": "~/.claude/skills/atrium/skill.md",
  "skillsDir": "~/.claude/skills",
  "binaryDiscovery": {
    "commands": [
      "claude"
    ],
    "wellKnownPaths": [
      "~/.npm/bin/claude",
      "/usr/local/bin/claude",
      "/opt/homebrew/bin/claude",
      "~/.local/bin/claude"
    ]
  },
  "install": {
    "macos": {
      "cmd": "npm install -g @anthropic-ai/claude-code",
      "postInstallAuth": true
    },
    "linux": {
      "cmd": "npm install -g @anthropic-ai/claude-code",
      "postInstallAuth": true
    },
    "windows": {
      "cmd": "npm install -g @anthropic-ai/claude-code",
      "postInstallAuth": true
    }
  },
  "hooks": {
    "session-start": "atrium://hooks/claude-code/session-start",
    "session-end": "atrium://hooks/claude-code/session-end",
    "pre-tool-use": "atrium://hooks/claude-code/pre-tool-use",
    "post-tool-use": "atrium://hooks/claude-code/post-tool-use",
    "stop": "atrium://hooks/claude-code/stop",
    "notification": "atrium://hooks/claude-code/notification",
    "user-prompt-submit": "atrium://hooks/claude-code/user-prompt-submit",
    "permission-request": "atrium://hooks/claude-code/permission-request",
    "subagent-start": "atrium://hooks/claude-code/subagent-start",
    "subagent-stop": "atrium://hooks/claude-code/subagent-stop",
    "stop-failure": "atrium://hooks/claude-code/stop-failure"
  },
  "methods": {
    "list_recent_sessions": {
      "script": "list_recent_sessions.sh"
    },
    "build_launch_command": {
      "script": "build_launch_command.sh"
    },
    "build_resume_command": {
      "script": "build_resume_command.sh"
    },
    "hooks": {
      "script": "hooks.sh"
    },
    "launcher_options": {
      "static": "launcher_options.json"
    },
    "list_plugin_skills": {
      "script": "list_plugin_skills.sh"
    },
    "continue_args": {
      "static": "continue_args.json"
    }
  },
  "retention": {
    "fields": [
      {
        "key": "days",
        "label": "Cleanup period",
        "unit": "d",
        "default": 30,
        "recommended": 365,
        "min": 1,
        "max": 99999
      }
    ],
    "readScript": "retention.read.sh",
    "writeScript": "retention.write.sh"
  },
  "sessionExtractor": {
    "script": "extract_session.sh",
    "schemaVersion": 1,
    "supportsDepths": [
      "quick",
      "standard",
      "deep"
    ]
  },
  "hookEnvelopes": {
    "sessionStartManifest": {
      "kind": "identity"
    },
    "userPromptSubmit": {
      "kind": "hookSpecificOutput",
      "hookEventName": "UserPromptSubmit",
      "includeSystemMessage": true
    },
    "preToolUse": {
      "kind": "hookSpecificOutput",
      "hookEventName": "PreToolUse",
      "includeSystemMessage": false
    },
    "postToolUse": {
      "kind": "hookSpecificOutput",
      "hookEventName": "PostToolUse",
      "includeSystemMessage": false
    }
  }
}
