{
  "sdkVersion": 2,
  "name": "opencode",
  "displayName": "OpenCode",
  "description": "Open-source AI coding agent built for the terminal (opencode.ai)",
  "accent": "#a855f7",
  "binary": "opencode",
  "version": "0.1.0",
  "skillInstallPath": "~/.config/opencode/agent/atrium/SKILL.md",
  "skillsDir": "~/.config/opencode/agent",
  "binaryDiscovery": {
    "commands": ["opencode"],
    "wellKnownPaths": [
      "~/.opencode/bin/opencode",
      "/opt/homebrew/bin/opencode",
      "/usr/local/bin/opencode",
      "~/.npm/bin/opencode",
      "~/.local/bin/opencode",
      "~/.bun/bin/opencode"
    ]
  },
  "hooks": {
    "session-start": "atrium://hooks/opencode/session-start",
    "session-end": "atrium://hooks/opencode/session-end",
    "pre-tool-use": "atrium://hooks/opencode/pre-tool-use",
    "post-tool-use": "atrium://hooks/opencode/post-tool-use",
    "stop": "atrium://hooks/opencode/stop",
    "user-prompt-submit": "atrium://hooks/opencode/user-prompt-submit",
    "permission-request": "atrium://hooks/opencode/permission-request"
  },
  "methods": {
    "list_recent_sessions": { "script": "list_recent_sessions.sh" },
    "build_launch_command": { "script": "build_launch_command.sh" },
    "build_resume_command": { "script": "build_resume_command.sh" },
    "hooks": { "script": "hooks.sh" },
    "launcher_options": { "static": "launcher_options.json" }
  }
}
