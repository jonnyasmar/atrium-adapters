{
  "sdkVersion": 2,
  "name": "pi",
  "displayName": "Pi",
  "description": "Minimal terminal coding agent by Mario Zechner (pi.dev)",
  "accent": "#06b6d4",
  "binary": "pi",
  "version": "0.4.3",
  "icon": "icon.svg",
  "skillInstallPath": "~/.pi/agent/skills/atrium/SKILL.md",
  "skillsDir": "~/.pi/agent/skills",
  "binaryDiscovery": {
    "commands": [
      "pi"
    ],
    "wellKnownPaths": [
      "/opt/homebrew/bin/pi",
      "/usr/local/bin/pi",
      "~/.local/bin/pi",
      "~/.npm/bin/pi",
      "~/.bun/bin/pi"
    ]
  },
  "install": {
    "macos": {
      "cmd": "npm install -g --ignore-scripts @earendil-works/pi-coding-agent",
      "postInstallAuth": true
    },
    "linux": {
      "cmd": "npm install -g --ignore-scripts @earendil-works/pi-coding-agent",
      "postInstallAuth": true
    },
    "windows": {
      "cmd": "npm install -g --ignore-scripts @earendil-works/pi-coding-agent",
      "postInstallAuth": true
    }
  },
  "hooks": {
    "session-start": "atrium://hooks/pi/session-start",
    "session-end": "atrium://hooks/pi/session-end",
    "pre-tool-use": "atrium://hooks/pi/pre-tool-use",
    "post-tool-use": "atrium://hooks/pi/post-tool-use",
    "stop": "atrium://hooks/pi/stop",
    "user-prompt-submit": "atrium://hooks/pi/user-prompt-submit"
  },
  "methods": {
    "build_launch_command": {
      "script": "build_launch_command.sh"
    },
    "build_resume_command": {
      "script": "build_resume_command.sh"
    },
    "list_recent_sessions": {
      "script": "list_recent_sessions.sh"
    },
    "hooks": {
      "script": "hooks.sh"
    },
    "launcher_options": {
      "static": "launcher_options.json"
    }
  },
  "sessionExtractor": {
    "script": "extract_session.sh",
    "schemaVersion": 1,
    "supportsDepths": [
      "quick",
      "standard",
      "deep"
    ]
  },
  "hookEnvelopes": {
    "sessionStartManifest": {
      "kind": "identity"
    },
    "userPromptSubmit": {
      "kind": "hookSpecificOutput",
      "hookEventName": "UserPromptSubmit",
      "includeSystemMessage": false
    },
    "preToolUse": {
      "kind": "none"
    },
    "postToolUse": {
      "kind": "hookSpecificOutput",
      "hookEventName": "PostToolUse",
      "includeSystemMessage": false
    }
  }
}
