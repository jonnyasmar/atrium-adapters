{
  "sdkVersion": 2,
  "name": "codex",
  "displayName": "Codex",
  "description": "OpenAI's AI coding assistant",
  "accent": "#059669",
  "binary": "codex",
  "version": "1.17.7",
  "icon": "icon.svg",
  "skillInstallPath": "~/.codex/skills/atrium/SKILL.md",
  "skillsDir": "~/.codex/skills",
  "binaryDiscovery": {
    "commands": [
      "codex"
    ],
    "wellKnownPaths": [
      "~/.npm/bin/codex",
      "/usr/local/bin/codex",
      "/opt/homebrew/bin/codex",
      "~/.local/bin/codex",
      "~/.cargo/bin/codex"
    ]
  },
  "install": {
    "macos": {
      "cmd": "npm install -g @openai/codex",
      "postInstallAuth": true
    },
    "linux": {
      "cmd": "npm install -g @openai/codex",
      "postInstallAuth": true
    },
    "windows": {
      "cmd": "npm install -g @openai/codex",
      "postInstallAuth": true
    }
  },
  "hooks": {
    "session-start": "atrium://hooks/codex/session-start",
    "session-end": "atrium://hooks/codex/session-end",
    "pre-tool-use": "atrium://hooks/codex/pre-tool-use",
    "post-tool-use": "atrium://hooks/codex/post-tool-use",
    "stop": "atrium://hooks/codex/stop",
    "user-prompt-submit": "atrium://hooks/codex/user-prompt-submit",
    "permission-request": "atrium://hooks/codex/permission-request"
  },
  "methods": {
    "list_recent_sessions": {
      "script": "list_recent_sessions.sh"
    },
    "build_launch_command": {
      "script": "build_launch_command.sh"
    },
    "build_resume_command": {
      "script": "build_resume_command.sh"
    },
    "hooks": {
      "script": "hooks.sh"
    },
    "launcher_options": {
      "static": "launcher_options.json"
    }
  },
  "sessionExtractor": {
    "script": "extract_session.sh",
    "schemaVersion": 1,
    "supportsDepths": [
      "quick",
      "standard",
      "deep"
    ]
  },
  "hookEnvelopes": {
    "sessionStartManifest": {
      "kind": "identity"
    },
    "userPromptSubmit": {
      "kind": "hookSpecificOutput",
      "hookEventName": "UserPromptSubmit",
      "includeSystemMessage": false
    },
    "preToolUse": {
      "kind": "hookSpecificOutput",
      "hookEventName": "PreToolUse",
      "includeSystemMessage": false
    },
    "postToolUse": {
      "kind": "hookSpecificOutput",
      "hookEventName": "PostToolUse",
      "includeSystemMessage": false
    }
  }
}
