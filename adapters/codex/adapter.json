{
  "sdkVersion": 2,
  "name": "codex",
  "displayName": "Codex",
  "description": "OpenAI's AI coding assistant",
  "accent": "#059669",
  "binary": "codex",
  "version": "1.12.1",
  "binaryDiscovery": {
    "commands": ["codex"],
    "wellKnownPaths": [
      "~/.npm/bin/codex",
      "/usr/local/bin/codex",
      "/opt/homebrew/bin/codex",
      "~/.local/bin/codex",
      "~/.cargo/bin/codex"
    ]
  },
  "hooks": {
    "session-start": "atrium://hooks/codex/session-start",
    "session-end": "atrium://hooks/codex/session-end",
    "pre-tool-use": "atrium://hooks/codex/pre-tool-use",
    "post-tool-use": "atrium://hooks/codex/post-tool-use",
    "stop": "atrium://hooks/codex/stop",
    "user-prompt-submit": "atrium://hooks/codex/user-prompt-submit"
  },
  "methods": {
    "list_recent_sessions": { "script": "list_recent_sessions.sh" },
    "build_launch_command": { "script": "build_launch_command.sh" },
    "build_resume_command": { "script": "build_resume_command.sh" },
    "hooks": { "script": "hooks.sh" },
    "launcher_options": { "static": "launcher_options.json" }
  }
}
