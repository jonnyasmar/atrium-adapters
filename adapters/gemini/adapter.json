{
  "sdkVersion": 2,
  "name": "gemini",
  "displayName": "Gemini CLI",
  "description": "Google's AI coding assistant",
  "accent": "#4285f4",
  "binary": "gemini",
  "version": "0.5.2",
  "skillInstallPath": "~/.gemini/skills/atrium/SKILL.md",
  "skillsDir": "~/.gemini/skills",
  "binaryDiscovery": {
    "commands": [
      "gemini"
    ],
    "wellKnownPaths": [
      "/opt/homebrew/bin/gemini",
      "/usr/local/bin/gemini",
      "~/.local/bin/gemini",
      "~/.npm/bin/gemini"
    ]
  },
  "hooks": {
    "session-start": "atrium://hooks/gemini/session-start",
    "session-end": "atrium://hooks/gemini/session-end",
    "user-prompt-submit": "atrium://hooks/gemini/user-prompt-submit",
    "pre-tool-use": "atrium://hooks/gemini/pre-tool-use",
    "post-tool-use": "atrium://hooks/gemini/post-tool-use",
    "stop": "atrium://hooks/gemini/stop",
    "notification": "atrium://hooks/gemini/notification"
  },
  "methods": {
    "build_launch_command": {
      "script": "build_launch_command.sh"
    },
    "build_resume_command": {
      "script": "build_resume_command.sh"
    },
    "list_recent_sessions": {
      "script": "list_recent_sessions.sh"
    },
    "hooks": {
      "script": "hooks.sh"
    },
    "launcher_options": {
      "static": "launcher_options.json"
    }
  },
  "retention": {
    "fields": [
      {
        "key": "days",
        "label": "Max age",
        "unit": "d",
        "default": 30,
        "recommended": 365,
        "min": 1,
        "max": 99999
      },
      {
        "key": "maxCount",
        "label": "Max sessions",
        "default": 100,
        "recommended": 1000,
        "min": 1,
        "max": 999999
      }
    ],
    "readScript": "retention.read.sh",
    "writeScript": "retention.write.sh"
  },
  "sessionExtractor": {
    "script": "extract_session.sh",
    "schemaVersion": 1,
    "supportsDepths": [
      "quick",
      "standard",
      "deep"
    ]
  },
  "hookEnvelopes": {
    "sessionStartManifest": {
      "kind": "hookSpecificOutput",
      "hookEventName": "SessionStart"
    },
    "userPromptSubmit": {
      "kind": "hookSpecificOutput",
      "hookEventName": "BeforeAgent",
      "includeSystemMessage": true
    },
    "preToolUse": {
      "kind": "none"
    }
  }
}
