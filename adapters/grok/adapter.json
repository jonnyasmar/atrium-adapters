{
  "sdkVersion": 2,
  "name": "grok",
  "displayName": "Grok",
  "description": "xAI's terminal coding agent",
  "accent": "#e11d48",
  "binary": "grok",
  "version": "0.4.2",
  "icon": "icon.svg",
  "skillInstallPath": "~/.grok/skills/atrium/SKILL.md",
  "skillsDir": "~/.grok/skills",
  "binaryDiscovery": {
    "commands": [
      "grok"
    ],
    "wellKnownPaths": [
      "~/.grok/bin/grok",
      "/usr/local/bin/grok",
      "/opt/homebrew/bin/grok",
      "~/.local/bin/grok"
    ]
  },
  "install": {
    "macos": {
      "cmd": "curl -fsSL https://x.ai/cli/install.sh | bash",
      "postInstallAuth": true
    },
    "linux": {
      "cmd": "curl -fsSL https://x.ai/cli/install.sh | bash",
      "postInstallAuth": true
    },
    "windows": {
      "cmd": "irm https://x.ai/cli/install.ps1 | iex",
      "postInstallAuth": true
    }
  },
  "hooks": {
    "session-start": "atrium://hooks/grok/session-start",
    "session-end": "atrium://hooks/grok/session-end",
    "pre-tool-use": "atrium://hooks/grok/pre-tool-use",
    "post-tool-use": "atrium://hooks/grok/post-tool-use",
    "stop": "atrium://hooks/grok/stop",
    "stop-failure": "atrium://hooks/grok/stop-failure",
    "notification": "atrium://hooks/grok/notification",
    "user-prompt-submit": "atrium://hooks/grok/user-prompt-submit",
    "subagent-start": "atrium://hooks/grok/subagent-start",
    "subagent-stop": "atrium://hooks/grok/subagent-stop"
  },
  "methods": {
    "list_recent_sessions": {
      "script": "list_recent_sessions.sh"
    },
    "build_launch_command": {
      "script": "build_launch_command.sh"
    },
    "build_resume_command": {
      "script": "build_resume_command.sh"
    },
    "hooks": {
      "script": "hooks.sh"
    },
    "launcher_options": {
      "static": "launcher_options.json"
    }
  },
  "sessionExtractor": {
    "script": "extract_session.sh",
    "schemaVersion": 1,
    "supportsDepths": [
      "quick",
      "standard",
      "deep"
    ]
  },
  "hookEnvelopes": {
    "sessionStartManifest": {
      "kind": "none"
    },
    "userPromptSubmit": {
      "kind": "none"
    },
    "preToolUse": {
      "kind": "none"
    },
    "postToolUse": {
      "kind": "none"
    }
  }
}
