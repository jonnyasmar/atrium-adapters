{
  "sdkVersion": 2,
  "name": "omp",
  "displayName": "Oh My Pi",
  "description": "Oh My Pi — extended pi-fork coding agent by can1357 (omp.sh)",
  "accent": "#f97316",
  "binary": "omp",
  "version": "16.3.4",
  "icon": "icon.svg",
  "skillInstallPath": "~/.omp/agent/skills/atrium/SKILL.md",
  "skillsDir": "~/.omp/agent/skills",
  "binaryDiscovery": {
    "commands": [
      "omp"
    ],
    "wellKnownPaths": [
      "~/.bun/bin/omp",
      "/opt/homebrew/bin/omp",
      "/usr/local/bin/omp",
      "~/.local/bin/omp",
      "~/.npm/bin/omp"
    ]
  },
  "install": {
    "macos": {
      "cmd": "npm install -g bun @oh-my-pi/pi-coding-agent",
      "postInstallAuth": true
    },
    "linux": {
      "cmd": "npm install -g bun @oh-my-pi/pi-coding-agent",
      "postInstallAuth": true
    },
    "windows": {
      "cmd": "npm install -g bun @oh-my-pi/pi-coding-agent",
      "postInstallAuth": true
    }
  },
  "hooks": {
    "session-start": "atrium://hooks/omp/session-start",
    "session-end": "atrium://hooks/omp/session-end",
    "pre-tool-use": "atrium://hooks/omp/pre-tool-use",
    "post-tool-use": "atrium://hooks/omp/post-tool-use",
    "stop": "atrium://hooks/omp/stop",
    "user-prompt-submit": "atrium://hooks/omp/user-prompt-submit"
  },
  "methods": {
    "build_launch_command": {
      "script": "build_launch_command.sh"
    },
    "build_resume_command": {
      "script": "build_resume_command.sh"
    },
    "list_recent_sessions": {
      "script": "list_recent_sessions.sh"
    },
    "hooks": {
      "script": "hooks.sh"
    },
    "launcher_options": {
      "static": "launcher_options.json"
    }
  },
  "sessionExtractor": {
    "script": "extract_session.sh",
    "schemaVersion": 1,
    "supportsDepths": [
      "quick",
      "standard",
      "deep"
    ]
  },
  "hookEnvelopes": {
    "sessionStartManifest": {
      "kind": "identity"
    },
    "userPromptSubmit": {
      "kind": "hookSpecificOutput",
      "hookEventName": "UserPromptSubmit",
      "includeSystemMessage": false
    },
    "preToolUse": {
      "kind": "none"
    },
    "postToolUse": {
      "kind": "hookSpecificOutput",
      "hookEventName": "PostToolUse",
      "includeSystemMessage": false
    }
  }
}
